      "parameters": {
        "jsCode": "// Format booking confirmation for VAPI response\nconst event = $input.first().json;\nconst extractData = $('Extract Tool Call').first().json;\n\nconst startTime = DateTime.fromISO(event.start.dateTime || event.start);\nconst formattedTime = startTime.toFormat('EEEE, MMMM d') + ' at ' + startTime.toFormat('h:mm a');\n\nreturn [{\n  json: {\n    toolCallId: extractData.toolCallId,\n    result: `Your ${extractData.serviceType} appointment has been booked for ${formattedTime}. We look forward to seeing you!`\n  }\n}];"
