{
  "name": "VAPI AI Receptionist",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Extract tool call data from VAPI webhook payload\nconst input = $input.first().json;\n\n// Webhook puts body in input.body\nconst body = input.body || input;\n\n// Validate payload structure\nif (!body.message || !body.message.toolCallList || !body.message.toolCallList[0]) {\n  throw new Error('Invalid VAPI payload: missing message.toolCallList');\n}\n\nconst toolCall = body.message.toolCallList[0];\n\n// Validate required fields\nif (!toolCall.id) {\n  throw new Error('Invalid VAPI payload: missing toolCallId');\n}\nif (!toolCall.function?.name) {\n  throw new Error('Invalid VAPI payload: missing function name');\n}\n\n// Parse arguments - VAPI sends as object or JSON string\nlet args = toolCall.function?.arguments || {};\nif (typeof args === 'string') {\n  try { args = JSON.parse(args); } catch (e) { args = {}; }\n}\n\n// Extract booking-specific arguments\nconst customerName = args.customerName || args.customer_name || args.name || 'Unknown Customer';\nconst serviceType = args.serviceType || args.service_type || args.type || 'Routine Maintenance';\nconst appointmentTime = args.appointmentTime || args.appointment_time || args.startTime || args.start_time;\nconst duration = args.duration || 60;\n\n// Extract logging-specific arguments (Phase 4)\nconst callerPhone = args.callerPhone || args.caller_phone || args.phone || args.callerNumber || '';\nconst toolCalled = args.toolCalled || args.tool_called || args.toolName || '';\nconst outcome = args.outcome || args.result || args.status || '';\nconst logDuration = args.duration || args.call_duration || args.durationSeconds || 0;\nconst argsString = args.arguments || args.args ? (typeof (args.arguments || args.args) === 'object' ? JSON.stringify(args.arguments || args.args) : args.arguments || args.args) : JSON.stringify(args);\n\nreturn [{\n  json: {\n    toolCallId: toolCall.id,\n    functionName: toolCall.function.name,\n    arguments: args,\n    startTime: args.date || args.startTime || args.start_time,\n    endTime: args.endDate || args.endTime || args.end_time,\n    customerName,\n    serviceType,\n    appointmentTime,\n    duration,\n    callerPhone,\n    toolCalled,\n    outcome,\n    logDuration,\n    argsString\n  }\n}];"
      },
