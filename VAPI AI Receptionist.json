    {
      "parameters": {
        "jsCode": "// Transform Google Calendar availability result for VAPI response\n// When calendar returns no busy slots, it outputs an empty object {}\n// Filter out empty objects before processing\nconst allItems = $input.all().map(item => item.json);\nconst busySlots = allItems.filter(slot => slot.start && slot.end);\nconst toolCallId = $('Extract Tool Call').first().json.toolCallId;\n\nlet result;\nif (busySlots.length === 0) {\n  result = \"The requested time slot is available. Would you like to book this appointment?\";\n} else {\n  const busyTimes = busySlots.map(slot => {\n    const start = DateTime.fromISO(slot.start);\n    const end = DateTime.fromISO(slot.end);\n    const startStr = start.toFormat('h:mm a');\n    const endStr = end.toFormat('h:mm a');\n    return `${startStr} to ${endStr}`;\n  }).join(', ');\n  \n  result = `That time slot is not available. We have appointments booked during: ${busyTimes}. Would you like to check a different time?`;\n}\n\nreturn [{\n  json: {\n    toolCallId,\n    result\n  }\n}];"
      },
